{
	"name": "number-packer",
	"version": "1.0.1",
	"description": "A versatile and efficient TypeScript library for packing/unpacking numbers of varying bit-lengths into compact binary buffers.",
	"bugs": {
		"url": "https://github.com/rizqi-uinpky/number-packer/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rizqi-uinpky/number-packer.git"
	},
	"homepage": "https://github.com/rizqi-uinpky/number-packer#readme",
	"license": "MIT",
	"author": "Ahmad Rizqi",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/number-packer.cjs",
	"module": "./dist/number-packer.js",
	"types": "./dist/number-packer.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/number-packer.d.ts",
				"default": "./dist/number-packer.js"
			},
			"require": {
				"types": "./dist/number-packer.d.cts",
				"default": "./dist/number-packer.cjs"
			}
		}
	},
	"sideEffects": false,
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"test": "vitest",
		"build": "npx tsup number-packer.ts --dts --format cjs,esm",
		"prepublishOnly": "npm run test && npm run build"
	},
	"devDependencies": {
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "^1.6.1"
	},
	"keywords": [
		"binary",
		"pack",
		"unpack",
		"bit",
		"bit-packing",
		"bitmask",
		"buffer",
		"serialization",
		"network",
		"protocol",
		"compact",
		"typescript",
		"bigint"
	]
}