{
	"name": "number-packer",
	"version": "1.0.1",
	"description": "A versatile and efficient TypeScript library for packing/unpacking numbers of varying bit-lengths into compact binary buffers.",
	"bugs": {
		"url": "https://github.com/rizqi-uinpky/number-packer/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rizqi-uinpky/number-packer.git"
	},
	"homepage": "https://github.com/rizqi-uinpky/number-packer#readme",
	"license": "MIT",
	"author": "Ahmad Rizqi",
	"type": "module",
	"main": "./dist/cjs/number-packer.js",
	"module": "./dist/esm/number-packer.js",
	"publishConfig": {
		"access": "public"
	},
	"types": "./dist/cjs/number-packer.d.ts",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/esm/number-packer.d.ts",
				"default": "./dist/esm/number-packer.js"
			},
			"require": {
				"types": "./dist/cjs/number-packer.d.ts",
				"default": "./dist/cjs/number-packer.js"
			}
		}
	},
	"sideEffects": false,
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"clean": "rm -rf ./dist",
		"test": "vitest",
		"build:esm": "tsc --project tsconfig.json --module NodeNext --outDir dist/esm",
		"build:cjs": "tsc --project tsconfig.json --module CommonJS --moduleResolution Node --outDir dist/cjs",
		"build": "npm run clean && npm run build:esm && npm run build:cjs && npm run postbuild",
		"postbuild": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json && echo '{\"type\": \"commonjs\"}' > ./dist/cjs/package.json",
		"prepublishOnly": "npm run test && npm run build"
	},
	"devDependencies": {
		"typescript": "^5.9.3",
		"vitest": "^1.6.1"
	},
	"keywords": [
		"binary",
		"pack",
		"unpack",
		"bit",
		"bit-packing",
		"bitmask",
		"buffer",
		"serialization",
		"network",
		"protocol",
		"compact",
		"typescript",
		"bigint"
	]
}
